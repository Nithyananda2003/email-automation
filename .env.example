# Copy to .env for local dev — on Render set these in the Dashboard > Environment

# IMAP Server Settings
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_ENCRYPTION=ssl
IMAP_USER=your-email@gmail.com
IMAP_PASS=your-app-password
IMAP_FOLDER=INBOX

# Defaults applied to every parsed order
DEFAULT_CUSTOMER_ID=
DEFAULT_DELIVERY_EMAIL=

# Server port (Render sets this automatically — do not override on Render)
PORT=3001
